# ============ API Credentials ============
GMAIL_CREDENTIALS_PATH=credentials.json
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json

# ============ LLM Configuration ============
LLM_PROVIDER=anthropic  # openai, anthropic, grok
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GROK_API_KEY=your_grok_key_here
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=60

# ============ RAG Configuration ============
VECTOR_DB_TYPE=chroma  # chroma or pgvector
VECTOR_DB_PATH=./data/vector_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
RETRIEVAL_K=5
RERANK_ENABLED=true

# ============ Processing Thresholds ============
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.8
REPLY_CONFIDENCE_THRESHOLD=0.75
CALENDAR_DETECTION_CONFIDENCE=0.7

# ============ API Rate Limiting ============
GMAIL_BATCH_SIZE=10
GMAIL_RATE_LIMIT_PER_MINUTE=60
CALENDAR_RATE_LIMIT_PER_MINUTE=60

# ============ Logging Configuration ============
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=./logs/smartmail.log
LOG_FORMAT=json  # json or text
MAX_LOG_FILE_SIZE=10485760  # 10MB

# ============ Database Configuration ============
SQLITE_DB_PATH=./data/smartmail.db

# ============ Feature Flags ============
ENABLE_HUMAN_REVIEW=true
ENABLE_AUTO_CALENDAR_CREATION=false
ENABLE_AUTO_REPLY_DRAFTING=true
DRY_RUN_MODE=false

# ============ LangSmith (Observability) ============
LANGSMITH_API_KEY=your_langsmith_key
LANGSMITH_PROJECT_NAME=smartmail-ai
ENABLE_LANGSMITH=false

# ============ Performance Settings ============
PARALLEL_PROCESSING=true
MAX_CONCURRENT_TASKS=5
CACHE_ENABLED=true
